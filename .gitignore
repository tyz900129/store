# ============================================
# PawPatrol Store · .gitignore
# ============================================

# ===== 敏感配置（绝对不能上传） =====
# 数据库配置（含密码）
**/db.properties
**/jdbc.properties
**/jdbc*.xml
**/application*.yml
**/application*.properties
**/config*.jsp
**/secret*.jsp

# 环境变量文件
.env
.env.local
.env.*.local

# 密钥 / 证书
*.key
*.pem
*.p12
*.pfx
keystore
truststore

# ===== Tomcat 运行时（不要提交运行时产物） =====
WEB-INF/work/
work/
logs/
temp/
tmp/

# ===== 用户上传内容（图片、附件、备份） =====
assets/uploads/
uploads/
static/uploads/
backup/
*.sql.bak
*.dump

# ===== IDE / 系统 =====
.idea/
.vscode/
*.iml
*.iws
*.ipr
.settings/
.project
.classpath
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo

# ===== SSH 密钥（绝对不能上传） =====
/.ssh
**/.ssh/
**/id_rsa*
**/id_ed25519*
**/id_ecdsa*

# ===== 日志 =====
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== 临时 / 构建产物 =====
*.tmp
*.bak
*.orig
*.rej
.tmp/

# ===== Node / 前端构建（如未来引入） =====
node_modules/
dist/
build/
.parcel-cache/
.next/
.nuxt/

# ===== Maven 产物（如未来引入） =====
target/
.mvn/
mvnw
mvnw.cmd

# ===== OS =====
.Trashes
.fseventsd
.Spotlight-V100
